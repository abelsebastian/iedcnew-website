# Supabase connection settings for the ksum-web SPA.
# Copy this file to `.env` and fill in the values from your Supabase project
# (Project Settings -> API). Do NOT commit your real `.env` file.

# The Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
# For local development this is typically http://127.0.0.1:54321
VITE_SUPABASE_URL=

# The Supabase anon/public API key (safe to expose to the browser).
VITE_SUPABASE_ANON_KEY=

# Google OAuth 2.0 credentials used by Supabase Auth's external Google provider
# (see supabase/config.toml -> [auth.external.google]). Obtain these from the
# Google Cloud Console (APIs & Services -> Credentials -> OAuth 2.0 Client IDs).
# Used for sign-up/sign-in via Google. Do NOT commit real values.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
